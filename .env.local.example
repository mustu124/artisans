# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas M0
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/artisan-root?retryWrites=true&w=majority
MONGODB_DB=artisan-root

# Admin auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-admin-password
# Optional safer alternative: remove ADMIN_PASSWORD and use a bcrypt hash instead.
# ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# WhatsApp orders
NEXT_PUBLIC_OWNER_WHATSAPP=91XXXXXXXXXX
